GOOGLE_API_KEY=your_google_ai_api_key
# Optional compatibility alias:
# GEMINI_API_KEY=your_google_ai_api_key

# Image backend selector
# google   -> Google GenAI (current default)
# together -> Together AI (DreamShaper, etc)
IMAGE_PROVIDER=google

# Image generation model
GOOGLE_IMAGE_MODEL=imagen-4.0-fast-generate-001

# Together AI (used only when IMAGE_PROVIDER=together)
TOGETHER_API_KEY=your_together_api_key
TOGETHER_IMAGE_MODEL=Lykon/DreamShaper

# Whisper speech-to-text (local/open-source)
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
AUDIO_SAMPLE_RATE=16000

# Output and cache behavior
OUTPUT_DIR=output
CACHE_VERSION=v3

# Sticker rendering for thermal printer
TARGET_WIDTH=384
THERMAL_WHITE_TARGET=0.88

# Prompt sanitization limits
MAX_PROMPT_WORDS=12
MAX_PROMPT_CHARS=80

# Logging
LOG_LEVEL=INFO
